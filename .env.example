# ═══════════════════════════════════════════════════════════════
# Augmentação de Assessores — Configuração por Job
# ═══════════════════════════════════════════════════════════════
#
# Cada job Cloud Run executa UM assessor.
# O prefixo identifica qual (ASSESSOR_1, ASSESSOR_2, etc).
#
# Para adicionar outro assessor:
#   1. Copie este arquivo com prefixo ASSESSOR_2
#   2. Crie um novo Cloud Run Job com ASSESSOR_PREFIX=ASSESSOR_2
#   3. Gere o base64 do creds.json do WhatsApp desse assessor
#   4. Preencha os IDs do Google Drive/Sheets dele
#
# ═══════════════════════════════════════════════════════════════

# ── Qual assessor este job executa ──────────────────
ASSESSOR_PREFIX=ASSESSOR_1

# ── Limite de envios por execução ───────────────────
ENVIOS_POR_EXECUCAO=8


# ═════════════════════════════════════════════════════
# ASSESSOR — Configuração de identidade
# ═════════════════════════════════════════════════════
ASSESSOR_1_NOME="Assessor XP"

# -- Google Gemini (IA) --
ASSESSOR_1_GEMINI_API_KEY="COLE_AQUI_SUA_CHAVE_GEMINI"
ASSESSOR_1_GEMINI_MODEL="gemini-3.1-flash-lite"

# -- Google Cloud (Service Account) --
# JSON completo em uma linha
ASSESSOR_1_GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"..."}'

# -- Google Drive --
ASSESSOR_1_ID_PASTA_PENDENTES="1w8i7sbDa7vchUnHLDIPw5x_W8pItKqkc"
ASSESSOR_1_ID_PASTA_PROCESSADOS="1SOtLs29vGzjWODhJqUS3xAU1LlW9-rlY"
ASSESSOR_1_ID_DOC_PERSONALIZACAO="1AGidw_UQ2LDhnTOfAcbA92W8ArsN6Zr2ztwCFQO9Y58"

# -- Google Sheets --
ASSESSOR_1_ID_PLANILHA_CLIENTES="1z_Sjv4nVDfR6nFtyvnI0RH4Q9a7wdn0frVKHVePJnyI"
ASSESSOR_1_NOME_ABA_CLIENTES="Clientes"
ASSESSOR_1_NOME_ABA_LOGS="Registros"

# -- WhatsApp (sessão Baileys) --
# Gere com: cat sessions/assessor1/creds.json | base64 -w0
ASSESSOR_1_BAILEYS_CREDS_B64="eyJub2lzZUtleS..."


# ═════════════════════════════════════════════════════
# JOB 2 — Exemplo para segundo assessor
# ═════════════════════════════════════════════════════
# ASSESSOR_PREFIX=ASSESSOR_2
# ASSESSOR_2_NOME="Maria Oliveira"
# ASSESSOR_2_GEMINI_API_KEY="..."
# ASSESSOR_2_GOOGLE_CREDENTIALS_JSON='{"type":"service_account",...}'
# ASSESSOR_2_ID_PASTA_PENDENTES="..."
# ASSESSOR_2_ID_PASTA_PROCESSADOS="..."
# ASSESSOR_2_ID_DOC_PERSONALIZACAO="..."
# ASSESSOR_2_ID_PLANILHA_CLIENTES="..."
# ASSESSOR_2_NOME_ABA_CLIENTES="Clientes"
# ASSESSOR_2_NOME_ABA_LOGS="Registros"
# ASSESSOR_2_BAILEYS_CREDS_B64="..."
